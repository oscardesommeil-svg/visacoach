# =====================================================================
# VisaCoach — Variables d'environnement (exemple)
# =====================================================================
# Copiez ce fichier en `backend/.env` pour le backend FastAPI.
# Les variables VITE_* vont dans `frontend/.env` (préfixe obligatoire pour Vite).
# Ne committez JAMAIS le vrai fichier .env, ni de vraies clés dans CE fichier.
# =====================================================================

# --- Général ---------------------------------------------------------
APP_NAME="VisaCoach API"
ENVIRONMENT=development
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Supabase --------------------------------------------------------
# Tableau de bord Supabase > Project Settings > API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# Clé service_role (SECRÈTE — backend uniquement)
SUPABASE_SERVICE_KEY=eyJhbGciOi...

# --- Claude (Anthropic) ----------------------------------------------
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
CLAUDE_MODEL=claude-sonnet-4-6

# --- CinetPay (FCFA / mobile money Afrique) --------------------------
CINETPAY_API_KEY=xxxxxxxx
CINETPAY_SITE_ID=123456
CINETPAY_BASE_URL=https://api-checkout.cinetpay.com/v2
CINETPAY_NOTIFY_URL=http://localhost:8000/api/payments/cinetpay/notify
CINETPAY_RETURN_URL=http://localhost:5173/success

# --- Stripe (EUR / diaspora) -----------------------------------------
STRIPE_SECRET_KEY=sk_test_xxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxx
STRIPE_SUCCESS_URL=http://localhost:5173/success?session_id={CHECKOUT_SESSION_ID}
STRIPE_CANCEL_URL=http://localhost:5173/rapport

# --- Resend (emails transactionnels) ---------------------------------
RESEND_API_KEY=re_xxxxxxxx
RESEND_FROM_EMAIL="VisaCoach <contact@visacoach.app>"

# --- Tarifs ----------------------------------------------------------
PRICE_RAPPORT_FCFA=6500
PRICE_RAPPORT_EUR_CENTS=990
PRICE_SUIVI_FCFA=19600
PRICE_SUIVI_EUR_CENTS=2990

# =====================================================================
# FRONTEND (frontend/.env) — préfixe VITE_ obligatoire
# =====================================================================
VITE_API_URL=http://localhost:8000
# Supabase Auth côté frontend (clé anon/public — JAMAIS la service_role)
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...anon...
